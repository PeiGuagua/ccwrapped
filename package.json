{
  "name": "ccwrapped",
  "version": "0.1.0",
  "description": "Claude Code daily wrapped — AI-narrated daily report with shareable image and optional email",
  "type": "module",
  "bin": {
    "ccwrapped": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude-code",
    "anthropic",
    "wrapped",
    "analytics",
    "cli",
    "daily-report"
  ],
  "license": "MIT",
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "fast-glob": "^3.3.2",
    "kleur": "^4.1.5",
    "openai": "^6.34.0",
    "resend": "^6.12.2",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
